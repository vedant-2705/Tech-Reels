{
  "defaultEnv": "default",
  "default": {
    "url": {
      "ENV": "DATABASE_URL"
    },
    "user": {
      "ENV": "DB_USER"
    },
    "password": {
      "ENV": "DB_PASSWORD"
    },
    "host": {
      "ENV": "DB_HOST"
    },
    "port": {
      "ENV": "DB_PORT"
    },
    "database": {
      "ENV": "DB_NAME"
    },
    "migrationsTable": "pgmigrations",
    "dir": "src/database/migrations",
    "direction": "up",
    "count": 1000,
    "ignorePattern": "^$",
    "decamelize": false
  }
}