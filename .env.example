# App
NODE_ENV=development
PORT=3000
API_BASE_URL=<base-url-here>
 
# PostgreSQL 
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tech_reel
DB_USER=postgres
DB_PASSWORD=<password-here>
DATABASE_URL=postgresql://postgres:<password-here>@localhost:5432/tech_reel

# Redis (Docker) 
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<password-here>


# JWT - RS256 access token
# Paste the full PEM content (newlines as \n)
# Run: npm run generate:keys  to create these 
JWT_PRIVATE_KEY=<private-key-here>
JWT_PUBLIC_KEY=<public-key-here>

# JWT - HS256 refresh token (separate secret)
# Use a long random string, e.g.: openssl rand -hex 64 
JWT_REFRESH_SECRET=<refresh-secret-here>

JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# OAuth 
OAUTH_REDIRECT_URI=http://localhost:3000
GOOGLE_CLIENT_ID=<google-client-id-here>
GOOGLE_CLIENT_SECRET=<google-client-secret-here>

GITHUB_CLIENT_ID=<github-client-id-here>
GITHUB_CLIENT_SECRET=<github-client-secret-here>

# AWS S3
AWS_REGION=<aws-region-here>
AWS_ACCESS_KEY_ID=<aws-access-key-id-here>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key-here>
S3_RAW_BUCKET=<s3-raw-bucket-name-here>
S3_CDN_BUCKET=<s3-cdn-bucket-name-here>
CDN_BASE_URL=https://<cdn-bucket-name>.amazonaws.com/

MEDIACONVERT_ENDPOINT=https://mediaconvert.<aws-region>.amazonaws.com
MEDIACONVERT_ROLE_ARN=arn:aws:iam::<aws-account-id>:role/service-role/MediaConvert_Default_Role
WEBHOOK_SECRET=<webhook-secret-here>

# Internal
INTERNAL_WEBHOOK_IPS=<comma-separated-list-of-internal-ips-or-cidrs>

# Admin user seeding (scripts/seed-admin.ts)
ADMIN_EMAIL=admin@techreel.io
ADMIN_USERNAME=techreel_admin
ADMIN_PASSWORD=<admin-password-here>